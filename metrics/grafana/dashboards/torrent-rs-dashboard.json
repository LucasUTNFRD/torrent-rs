{
  "title": "Torrent-rs Metrics Dashboard",
  "timezone": "browser",
  "refresh": "5s",
  "schemaVersion": 38,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "default",
          "value": "default"
        },
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Torrents Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "torrent_downloading",
          "legendFormat": "Downloading",
          "refId": "A"
        },
        {
          "expr": "torrent_seeding",
          "legendFormat": "Seeding",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Peers Connected",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "net_peers_connected",
          "legendFormat": "Peers",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "DHT Details",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "dht_nodes",
          "legendFormat": "Nodes",
          "refId": "A"
        },
        {
          "expr": "dht_peers",
          "legendFormat": "Peers",
          "refId": "B"
        },
        {
          "expr": "dht_torrents",
          "legendFormat": "Torrents",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "title": "Traffic Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(traffic_recv_payload_bytes[1m])",
          "legendFormat": "Recv Payload",
          "refId": "A"
        },
        {
          "expr": "rate(traffic_sent_payload_bytes[1m])",
          "legendFormat": "Sent Payload",
          "refId": "B"
        },
        {
          "expr": "rate(traffic_recv_bytes[1m])",
          "legendFormat": "Recv Total",
          "refId": "C"
        },
        {
          "expr": "rate(traffic_sent_bytes[1m])",
          "legendFormat": "Sent Total",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Disk I/O Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(disk_bytes_read[1m])",
          "legendFormat": "Bytes Read",
          "refId": "A"
        },
        {
          "expr": "rate(disk_bytes_written[1m])",
          "legendFormat": "Bytes Written",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Piece Events Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(bt_piece_requests[1m])",
          "legendFormat": "Requests",
          "refId": "A"
        },
        {
          "expr": "rate(bt_piece_passed[1m])",
          "legendFormat": "Passed",
          "refId": "B"
        },
        {
          "expr": "rate(bt_piece_failed[1m])",
          "legendFormat": "Failed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Disk Latency (Avg)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(disk_read_time_ms_sum[1m]) / rate(disk_read_time_ms_count[1m])",
          "legendFormat": "Read Latency",
          "refId": "A"
        },
        {
          "expr": "rate(disk_write_time_ms_sum[1m]) / rate(disk_write_time_ms_count[1m])",
          "legendFormat": "Write Latency",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "id": 8,
      "title": "DHT Messages Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(dht_messages_in[1m])",
          "legendFormat": "In",
          "refId": "A"
        },
        {
          "expr": "rate(dht_messages_out[1m])",
          "legendFormat": "Out",
          "refId": "B"
        },
        {
          "expr": "rate(dht_messages_dropped[1m])",
          "legendFormat": "Dropped",
          "refId": "C"
        },
        {
          "expr": "rate(dht_messages_out_dropped[1m])",
          "legendFormat": "Out Dropped",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msgps",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Connection Events Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(net_connection_attempts[1m])",
          "legendFormat": "Attempts",
          "refId": "A"
        },
        {
          "expr": "rate(net_incoming_connections[1m])",
          "legendFormat": "Incoming",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Socket Operations Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "rate(net_reads[1m])",
          "legendFormat": "Reads",
          "refId": "A"
        },
        {
          "expr": "rate(net_writes[1m])",
          "legendFormat": "Writes",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "axisPlacement": "left",
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          }
        }
      }
    }
  ]
}